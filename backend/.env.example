# Copy to .env and adjust, or just export these in your shell before running uvicorn.
# (main.py's config.py reads these via os.environ — nothing loads .env automatically
# unless you `export $(cat .env | xargs)` or use `uvicorn --env-file .env`.)

# Root of Talos's local state. Default if unset: ~/.talos
TALOS_HOME=

# The `talos` executable to invoke. Default if unset: "talos" (looked up on PATH)
TALOS_BIN=talos

# Timeout in seconds for a single CLI invocation.
TALOS_CP_CLI_TIMEOUT=60

# Where this control panel's own API listens.
CP_HOST=127.0.0.1
CP_PORT=8420
