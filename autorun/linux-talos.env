# ---------------------------------------------------------------------------
# Talos Control Panel — Linux path configuration
# Edit these values to match this machine, then run: ./run-talos-cp.sh
# This file is `source`d by run-talos-cp.sh — keep it as plain KEY=VALUE,
# no spaces around '=', quote values that contain spaces.
# ---------------------------------------------------------------------------

# Root of the main Talos repo (contains pyproject.toml, the talos/ package)
TALOS_ROOT="$HOME/project-tool-scripts-whatnot/talos"

# Root of the talos-control-panel repo (contains backend/ and frontend/)
CP_ROOT="$HOME/project-tool-scripts-whatnot/talos-control-panel/"

# Talos's on-disk state (registry.json, per-project SQLite dbs). Leave as
# default unless you've pointed Talos somewhere else.
TALOS_HOME="$HOME/.talos"

# Ports
CP_BACKEND_PORT=8420
CP_FRONTEND_PORT=5173

# Optional: path to Talos's own venv, if it lives somewhere other than
# TALOS_ROOT/.venv. Leave commented out to use the default.
# TALOS_VENV="$HOME/somewhere-else/.venv"
